# =====================================================
# AI Report Generator - Environment Variables Example
# =====================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Google Gemini API ---
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- MongoDB ---
# Local: mongodb://localhost:27017/ai_report_generator
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/ai_report_generator
MONGO_URI=mongodb://localhost:27017/ai_report_generator

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# --- CORS ---
# Frontend URL (Vite default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173
